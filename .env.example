# Supabase — public keys (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase — service role key (server-only, never expose to the browser)
# Found in: Supabase Dashboard > Settings > API > service_role key
# Required for atomic coupon operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin / portal session signing secret
# Used to sign yl_portal_session HMAC cookies for staff/admin access
# Falls back to ADMIN_PANEL_TOKEN if PORTAL_SESSION_SECRET is not set
PORTAL_SESSION_SECRET=change_me_to_a_long_random_string

# Legacy admin panel token (used as fallback signing key if PORTAL_SESSION_SECRET is absent)
ADMIN_PANEL_TOKEN=change_me

# Staff portal password (used on the /redeem login page)
STAFF_PORTAL_PASSWORD=change_me
STAFF_TOKEN=change_me

# Base URL — used for QR code generation and absolute links
# Set to your production domain in prod (e.g. https://game.yogurtland.com)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
